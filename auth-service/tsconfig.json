{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": "./",
    "paths": {
      "@model/*": ["src/models/*"],
      "@db/*": ["src/db/*"],
      "@service/*": ["src/service/*"],
      "@resolvers/*": ["src/resolvers/*"],
      "@controller/*": ["src/controller/*"],
      "@test/*": ["__test__/*"],
      "@schema/*": ["src/schema/*"]
    },
  }
}
